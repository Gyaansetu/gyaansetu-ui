import { useState } from 'react';
import Navbar from '../components/layout/Navbar';
import Footer from '../components/layout/Footer';
import Toast from '../components/common/Toast';
import useToast from '../hooks/useToast';

const TutorPoolPage = ({ onOpenLogin, onOpenRegister, onNavigateToFindTutor, onNavigateToNotifications, onNavigateToProfile, onNavigateToAdminBooking, onNavigateToAdminDashboard, onNavigateHome }) => {
  const { toast, showSuccess, showError, hideToast } = useToast();
  const [userRole] = useState('TUTOR'); // TODO: Get from auth context - 'ADMIN' or 'TUTOR'
  const [currentTutorName] = useState('Current Tutor'); // TODO: Get from auth context

  // Mock demo events data - will come from backend API
  const [demoEvents, setDemoEvents] = useState([
    {
      id: 1,
      address: 'Sector 15, Rohini, New Delhi - 110085',
      classes: ['Class 10', 'Class 12'],
      subjects: ['Mathematics', 'Physics'],
      priceOffered: 1500,
      status: 'PENDING',
      bookedBy: [],
      maxBookings: 3,
      postedBy: 'Admin',
      postedAt: '2026-02-11T10:30:00',
    },
    {
      id: 2,
      address: 'Dwarka Sector 7, New Delhi - 110075',
      classes: ['Class 8', 'Class 9'],
      subjects: ['Science', 'English'],
      priceOffered: 1200,
      status: 'PENDING',
      bookedBy: ['Tutor A'],
      maxBookings: 3,
      postedBy: 'Admin',
      postedAt: '2026-02-11T09:15:00',
    },
    {
      id: 3,
      address: 'Vasant Kunj, New Delhi - 110070',
      classes: ['Class 11', 'Class 12'],
      subjects: ['Chemistry', 'Biology'],
      priceOffered: 1800,
      status: 'BOOKED',
      bookedBy: ['Tutor A', 'Tutor B', 'Tutor C'],
      maxBookings: 3,
      postedBy: 'Admin',
      postedAt: '2026-02-10T16:45:00',
    },
    {
      id: 4,
      address: 'Janakpuri, New Delhi - 110058',
      classes: ['Class 6', 'Class 7'],
      subjects: ['Mathematics', 'Hindi'],
      priceOffered: 1000,
      status: 'EXPIRED',
      bookedBy: ['Tutor X'],
      maxBookings: 3,
      postedBy: 'Admin',
      postedAt: '2026-02-09T14:20:00',
    },
  ]);

  const handleBookDemo = (eventId) => {
    const event = demoEvents.find(e => e.id === eventId);
    
    if (!event) return;

    if (event.status === 'BOOKED') {
      showError('This event is already fully booked');
      return;
    }

    if (event.status === 'EXPIRED') {
      showError('This event has expired');
      return;
    }

    if (event.bookedBy.length >= event.maxBookings) {
      showError('Maximum bookings reached for this event');
      return;
    }

    // Check if tutor already booked this event
    if (event.bookedBy.includes(currentTutorName)) {
      showError('You have already booked this event');
      return;
    }

    // TODO: API call to book the demo
    
    setDemoEvents(prevEvents =>
      prevEvents.map(e =>
        e.id === eventId
          ? {
              ...e,
              bookedBy: [...e.bookedBy, currentTutorName],
              status: e.bookedBy.length + 1 >= e.maxBookings ? 'BOOKED' : e.status,
            }
          : e
      )
    );

    showSuccess('Demo booked successfully! Admin will contact you soon.', 4000);
  };

  const handleCancelBooking = (eventId) => {
    const event = demoEvents.find(e => e.id === eventId);
    
    if (!event) return;

    // Check if tutor has booked this event
    if (!event.bookedBy.includes(currentTutorName)) {
      showError('You have not booked this event');
      return;
    }

    // TODO: API call to cancel the booking
    
    setDemoEvents(prevEvents =>
      prevEvents.map(e =>
        e.id === eventId
          ? {
              ...e,
              bookedBy: e.bookedBy.filter(name => name !== currentTutorName),
              status: 'PENDING', // Reset to PENDING when a slot becomes available
            }
          : e
      )
    );

    showSuccess('Booking cancelled successfully!', 3000);
  };

  const getStatusBadge = (status) => {
    const styles = {
      PENDING: 'bg-yellow-100 text-yellow-800 border-yellow-300',
      BOOKED: 'bg-green-100 text-green-800 border-green-300',
      EXPIRED: 'bg-gray-100 text-gray-800 border-gray-300',
    };

    return (
      <span className={`px-3 py-1 rounded-full text-xs font-semibold border ${styles[status]}`}>
        {status}
      </span>
    );
  };

  const formatDate = (dateString) => {
    const date = new Date(dateString);
    const now = new Date();
    const diffMs = now - date;
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMs / 3600000);
    const diffDays = Math.floor(diffMs / 86400000);

    if (diffMins < 60) return `${diffMins} minutes ago`;
    if (diffHours < 24) return `${diffHours} hours ago`;
    if (diffDays === 1) return 'Yesterday';
    return date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
  };

  return (
    <div className="min-h-screen bg-gray-50">
      <Navbar
        onOpenLogin={onOpenLogin}
        onOpenRegister={onOpenRegister}
        onNavigateToFindTutor={onNavigateToFindTutor}
        onNavigateToNotifications={onNavigateToNotifications}
        onNavigateToProfile={onNavigateToProfile}
        onNavigateToAdminBooking={onNavigateToAdminBooking}
        onNavigateToAdminDashboard={onNavigateToAdminDashboard}
        onNavigateHome={onNavigateHome}
        currentPage="tutor-pool"
      />

      <main className="pt-20">
        {/* Header Section */}
        <div className="bg-teal-500 text-white py-12">
          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div className="flex items-center justify-between">
              <div>
                <h1 className="text-4xl font-bold mb-2">Tutor Pool</h1>
                <p className="text-lg text-teal-50">
                  {userRole === 'ADMIN' 
                    ? 'Post demo requests and manage bookings' 
                    : 'Browse and book demo opportunities'}
                </p>
              </div>
              <div className="bg-white/20 backdrop-blur-sm px-6 py-3 rounded-full">
                <span className="text-white font-semibold text-lg">
                  {demoEvents.filter(e => e.status === 'PENDING').length} Active Events
                </span>
              </div>
            </div>
          </div>
        </div>

        {/* Main Content */}
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          {/* Info Banner */}
          <div className="bg-blue-50 border-l-4 border-blue-500 p-4 mb-6 rounded-r-lg">
            <div className="flex items-start">
              <svg className="w-6 h-6 text-blue-500 mt-0.5 mr-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>
                <h3 className="text-sm font-semibold text-blue-900 mb-1">How it works</h3>
                <p className="text-sm text-blue-800">
                  {userRole === 'ADMIN'
                    ? 'Post demo requests for tutors to view. Each event can be booked by up to 3 tutors. Manage bookings manually after tutors express interest.'
                    : 'Browse demo opportunities posted by admin. Book events you\'re interested in (max 3 tutors per event). Admin will contact you for the next steps.'}
                </p>
              </div>
            </div>
          </div>

          {/* Demo Events List */}
          <div className="space-y-4">
            <h2 className="text-2xl font-bold text-gray-900 mb-4">Demo Requests</h2>
            
            {demoEvents.length === 0 ? (
              <div className="bg-white rounded-xl shadow-sm p-12 text-center">
                <svg className="w-16 h-16 text-gray-400 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                </svg>
                <h3 className="text-lg font-semibold text-gray-900 mb-2">No demo requests yet</h3>
                <p className="text-gray-600">Check back later for new opportunities</p>
              </div>
            ) : (
              demoEvents.map((event) => (
                <div
                  key={event.id}
                  className="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow p-6 border-l-4 border-teal-500"
                >
                  {/* Event Header */}
                  <div className="flex items-start justify-between mb-4">
                    <div className="flex items-center gap-3">
                      <div className="w-12 h-12 bg-teal-100 rounded-full flex items-center justify-center flex-shrink-0">
                        <svg className="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                        </svg>
                      </div>
                      <div>
                        <p className="text-sm text-gray-500">Posted by {event.postedBy}</p>
                        <p className="text-xs text-gray-400">{formatDate(event.postedAt)}</p>
                      </div>
                    </div>
                    <div className="flex items-center gap-2">
                      {getStatusBadge(event.status)}
                    </div>
                  </div>

                  {/* Event Details */}
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                    {/* Address */}
                    <div className="flex items-start gap-3">
                      <svg className="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                      <div>
                        <p className="text-xs font-medium text-gray-500 uppercase mb-1">Location</p>
                        <p className="text-sm text-gray-900">{event.address}</p>
                      </div>
                    </div>

                    {/* Price */}
                    <div className="flex items-start gap-3">
                      <svg className="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <div>
                        <p className="text-xs font-medium text-gray-500 uppercase mb-1">Price Offered</p>
                        <p className="text-lg font-bold text-teal-600">₹{event.priceOffered}/month</p>
                      </div>
                    </div>

                    {/* Classes */}
                    <div className="flex items-start gap-3">
                      <svg className="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                      </svg>
                      <div>
                        <p className="text-xs font-medium text-gray-500 uppercase mb-1">Classes</p>
                        <div className="flex flex-wrap gap-1">
                          {event.classes.map((cls, idx) => (
                            <span key={idx} className="px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs font-medium">
                              {cls}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>

                    {/* Subjects */}
                    <div className="flex items-start gap-3">
                      <svg className="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                      </svg>
                      <div>
                        <p className="text-xs font-medium text-gray-500 uppercase mb-1">Subjects</p>
                        <div className="flex flex-wrap gap-1">
                          {event.subjects.map((subject, idx) => (
                            <span key={idx} className="px-2 py-1 bg-teal-100 text-teal-700 rounded text-xs font-medium">
                              {subject}
                            </span>
                          ))}
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Booking Info & Action */}
                  <div className="border-t pt-4 mt-4">
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-4">
                        <div className="flex items-center gap-2">
                          <svg className="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                          </svg>
                          <span className="text-sm text-gray-600">
                            {event.bookedBy.length} / {event.maxBookings} slots booked
                          </span>
                        </div>
                        {event.bookedBy.length > 0 && (
                          <div className="text-xs text-gray-500">
                            Booked by: {event.bookedBy.join(', ')}
                          </div>
                        )}
                      </div>

                      {/* Action Button */}
                      {userRole === 'TUTOR' && (
                        <div>
                          {event.bookedBy.includes(currentTutorName) ? (
                            // Cancel button if tutor has already booked
                            <button
                              onClick={() => handleCancelBooking(event.id)}
                              disabled={event.status === 'EXPIRED'}
                              className={`px-6 py-2 rounded-lg font-semibold transition-all ${
                                event.status !== 'EXPIRED'
                                  ? 'bg-red-600 text-white hover:bg-red-700 shadow-md hover:shadow-lg'
                                  : 'bg-gray-300 text-gray-500 cursor-not-allowed'
                              }`}
                            >
                              Cancel Booking
                            </button>
                          ) : (
                            // Book button if tutor hasn't booked yet
                            <button
                              onClick={() => handleBookDemo(event.id)}
                              disabled={event.status !== 'PENDING' || event.bookedBy.length >= event.maxBookings}
                              className={`px-6 py-2 rounded-lg font-semibold transition-all ${
                                event.status === 'PENDING' && event.bookedBy.length < event.maxBookings
                                  ? 'bg-teal-600 text-white hover:bg-teal-700 shadow-md hover:shadow-lg'
                                  : 'bg-gray-300 text-gray-500 cursor-not-allowed'
                              }`}
                            >
                              {event.status === 'BOOKED' ? 'Fully Booked' : event.status === 'EXPIRED' ? 'Expired' : 'Book Demo'}
                            </button>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              ))
            )}
          </div>
        </div>
      </main>

      <Footer />

      {/* Toast Notification */}
      <Toast
        type={toast.type}
        message={toast.message}
        isVisible={toast.isVisible}
        onClose={hideToast}
        duration={toast.duration}
      />
    </div>
  );
};

export default TutorPoolPage;
